# ─── AWS S3 Configuration ───────────────────────────────────────────────────
# Required for image uploads to S3 (used by POST /parse endpoint)

AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here
AWS_REGION=ap-south-1

# S3 bucket where question images are stored
S3_BUCKET_NAME=examsqa-question-images

# CDN URL prefix for generating public image URLs
# This should match your CloudFront distribution or S3 bucket URL
CDN_BASE_URL=https://cdn.examsqa.in/question-images

# ─── Parser API Configuration ──────────────────────────────────────────────
# Optional settings for the parser API

# API key for authenticating requests from Laravel (optional but recommended)
# PARSER_API_KEY=your-secret-api-key-here

# Maximum upload size in MB (default: 500)
# MAX_UPLOAD_SIZE_MB=500
